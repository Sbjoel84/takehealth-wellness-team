# PostgreSQL connection string (get this from Render or Neon)
DATABASE_URL="postgresql://user:password@host:5432/takehealth"

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-key-here"

# The URL where this backend is deployed
BETTER_AUTH_URL="https://take-health-web-api.onrender.com"

# The URL of the frontend (for CORS)
FRONTEND_URL="https://your-frontend.vercel.app"

PORT=5000
